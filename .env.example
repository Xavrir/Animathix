# Required
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional (premium voice providers)
ELEVENLABS_API_KEY=
OPENAI_API_KEY=

# Backend settings
# See https://openrouter.ai/models for available model slugs.
LLM_MODEL=qwen/qwen3.6-plus:free
MANIM_QUALITY=medium_quality
MEDIA_DIR=./media
MAX_RETRIES=5
RENDER_TIMEOUT=300

# Kokoro sidecar
KOKORO_SIDECAR_URL=http://127.0.0.1:9100
KOKORO_HEALTH_TIMEOUT=2.0
KOKORO_REQUEST_TIMEOUT=45.0
