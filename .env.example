# Required
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional (premium voice providers)
ELEVENLABS_API_KEY=
OPENAI_API_KEY=

# Backend settings
# See https://openrouter.ai/models for available model slugs.
LLM_MODEL=qwen/qwen3-coder:free
MANIM_QUALITY=medium_quality
MEDIA_DIR=./media
MAX_RETRIES=3
RENDER_TIMEOUT=300
OPENROUTER_TIMEOUT=45
INLINE_VOICEOVER_ENABLED=false
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_REQUEST_TIMEOUT=60

# Kokoro sidecar
KOKORO_SIDECAR_URL=http://127.0.0.1:9100
KOKORO_HEALTH_TIMEOUT=2.0
KOKORO_REQUEST_TIMEOUT=45.0
